# Starwaves deployment example
# Copy to your real environment file/process manager and replace values.

SITE_BASE_URL=https://www.starwaves.com.cn
STATIC_BASE_URL=https://static.starwaves.com.cn
MEDIA_BASE_URL=https://media.starwaves.com.cn

# Optional canonical cookie domain for multi-subdomain login.
COOKIE_DOMAIN=.starwaves.com.cn

# PHP / app runtime
APP_ENV=production
APP_DEBUG=0
TZ=Asia/Shanghai

# Baidu Netdisk runtime credentials should stay on the server only.
# Keep tokens/keys out of Git and inject them through your server environment.
BAIDU_NETDISK_ENABLED=1

# Software mastering integration
MASTERING_API_BASE=https://your-mastering-service.example.com
MASTERING_API_TOKEN=replace-me
MASTERING_CALLBACK_TOKEN=replace-me
MASTERING_CALLBACK_URL=https://www.starwaves.com.cn/backend/master_callback.php

# Example database/runtime notes
# This project currently includes SQLite-oriented code paths in repo.
# If you move to MySQL later, store DSN/user/password outside Git as well.
